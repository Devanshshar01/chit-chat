# Copy to .env and fill in for real use. Never commit the real .env.

DATABASE_URL=sqlite+aiosqlite:///./app.db
JWT_SECRET=replace-with-a-real-random-secret

# R2 (Cloudflare dashboard -> R2 -> Manage API tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=unnamed-chat-media

# Leave unset in production. Only for testing against a local moto server:
# S3_ENDPOINT_URL_OVERRIDE=http://127.0.0.1:5000

# Only used by app/seed.py - set these before running `python -m app.seed`
SEED_DEVANSH_PASSCODE=
SEED_SWARNIMA_PASSCODE=
